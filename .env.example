# Evo-server environment variables
# Copy to .env and fill in values

# Server
EVO_HOST=0.0.0.0
EVO_PORT=8090
EVO_DB_PATH=/opt/evo-server/data/evo.db

# Auth (CLI → server)
EVO_API_KEY=your-api-key-here

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_OWNER_ID=your-telegram-user-id
# TELEGRAM_API_BASE=https://your-cf-worker.workers.dev  # CF Worker proxy

# GitHub (for learning engine)
GITHUB_TOKEN=ghp_xxx
EVO_LEARN_LANGUAGES=python,rust,go,typescript

# Evolution tuning
EVO_EMA_SUCCESS=1.05
EVO_EMA_FAILURE=0.9
EVO_EVIDENCE_MIN=3
EVO_PASS_RATE_MIN=0.8

# LiMa cross-server sync
LIMA_SYNC_ENABLED=true
LIMA_SYNC_INTERVAL_HOURS=24
